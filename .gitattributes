# Git LFS — only for genuinely-large binaries.
# Small images (logos, icons, small photos) stay as regular Git blobs
# for simplicity and to avoid LFS budget constraints.
# If a photo is over ~5MB, manually flip its extension entry back to LFS.

# Images — NOT LFS by default.
#   *.jpg, *.jpeg, *.png, *.gif, *.webp, *.tiff, *.heic, *.avif
# If you add an image over ~5MB, consider:
#   - Downsizing first (sharp/ImageMagick/photoshop export)
#   - Or turning LFS back on for that single file

# Vector / design sources — LFS (these get big)
*.psd   filter=lfs diff=lfs merge=lfs -text
*.ai    filter=lfs diff=lfs merge=lfs -text
*.sketch filter=lfs diff=lfs merge=lfs -text
*.fig   filter=lfs diff=lfs merge=lfs -text

# Video — LFS (essentially always huge)
*.mp4   filter=lfs diff=lfs merge=lfs -text
*.mov   filter=lfs diff=lfs merge=lfs -text
*.webm  filter=lfs diff=lfs merge=lfs -text
*.m4v   filter=lfs diff=lfs merge=lfs -text

# Audio — LFS
*.mp3   filter=lfs diff=lfs merge=lfs -text
*.wav   filter=lfs diff=lfs merge=lfs -text
*.m4a   filter=lfs diff=lfs merge=lfs -text

# Archives / PDFs — LFS
*.pdf   filter=lfs diff=lfs merge=lfs -text
*.zip   filter=lfs diff=lfs merge=lfs -text
